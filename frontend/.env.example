# 프론트 Google OAuth 설정 (로컬 실행 기준: cd frontend && npm run dev)
# 실제 값은 frontend/.env.local 에 넣는다(.gitignore의 *.local 규칙으로 커밋되지 않음).
#
# 프론트에는 공개 가능한 값만 둔다. GOOGLE_CLIENT_SECRET / JWT_SECRET /
# JIPSA_FIELD_ENC_KEY / DB 관련 값은 절대 프론트에 넣지 않는다(백엔드 전용).

# 백엔드 GOOGLE_CLIENT_ID 와 동일한 값 (Google Cloud Console OAuth 클라이언트 ID)
VITE_GOOGLE_CLIENT_ID=

# 백엔드 GOOGLE_REDIRECT_URI, Google Cloud Console 승인된 리디렉션 URI 와 완전히 동일해야 함
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/callback
