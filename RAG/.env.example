# =========================================================
# Jipsa RAG Environment Variable Example
# =========================================================
# .env.local, .env.development, .env.test 작성 시 참고하는 예시입니다.
#
# 이 파일에는 실제 DB 비밀번호나 내부 인증 토큰을 입력하지 않습니다.
# .env.example만 Git에 커밋하고 실제 환경별 dotenv 파일은 제외합니다.
#
# RAG는 AWS Access Key, Secret Access Key 또는 Session Token을
# 사용하지 않습니다.
#
# S3 파일은 EC2 애플리케이션 서버가 IAM Role을 사용해 발급한
# Presigned GET URL을 통해 다운로드합니다.
#
# 실행 환경 선택:
# - 미지정      -> .env.local
# - development -> .env.development
# - test        -> .env.test
#
# development 실행 예시:
# $env:JIPSA_RAG_APP_ENV = "development"
# uv run uvicorn jipsa_rag.main:app --reload


# =========================================================
# Application
# =========================================================

# Swagger UI와 OpenAPI 문서에 표시할 서비스 이름입니다.
JIPSA_RAG_APP_NAME="Jipsa RAG Service"

# 현재 RAG 애플리케이션 버전입니다.
JIPSA_RAG_APP_VERSION=0.1.0

# RAG API v1 엔드포인트에 공통으로 적용할 prefix입니다.
JIPSA_RAG_API_V1_PREFIX=/api/v1

# RAG는 로컬 PC에서만 실행합니다.
JIPSA_RAG_HOST=127.0.0.1

# FastAPI 서버 포트입니다.
JIPSA_RAG_PORT=8000

# 디버그 모드 사용 여부입니다.
JIPSA_RAG_DEBUG=true


# =========================================================
# Internal Ingestion Authentication
# =========================================================

# 애플리케이션 서버가 POST /ingest 요청에 전달하는 공유 시크릿입니다.
#
# backend의 RAG_INGEST_TOKEN과 반드시 동일한 값을 설정합니다.
#
# 실제 토큰은 .env.local, .env.development 또는 .env.test에만 작성하고
# 이 예시 파일에는 실제 값을 커밋하지 않습니다.
#
# 최소 32자 이상의 예측하기 어려운 임의 문자열을 사용합니다.
RAG_INGEST_TOKEN=CHANGE_ME_TO_SECURE_RANDOM_TOKEN


# =========================================================
# Local RAG MySQL
# =========================================================

# Local RAG MySQL 서버 주소입니다.
JIPSA_RAG_DATABASE_HOST=127.0.0.1

# MySQL 기본 포트입니다.
JIPSA_RAG_DATABASE_PORT=3306

# Local RAG 데이터베이스 이름입니다.
JIPSA_RAG_DATABASE_NAME=Jipsa_Local_RAG

# Local RAG 데이터베이스 접속 계정입니다.
JIPSA_RAG_DATABASE_USER=jipsa

# 실제 환경별 dotenv 파일에서 MySQL 비밀번호로 교체합니다.
JIPSA_RAG_DATABASE_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# Local RAG DDL에서 사용하는 문자 집합입니다.
JIPSA_RAG_DATABASE_CHARSET=utf8mb4

# 애플리케이션 시작 시 SELECT 1 연결 검사 여부입니다.
JIPSA_RAG_DATABASE_CHECK_ON_STARTUP=true

# SQLAlchemy SQL 출력 여부입니다.
JIPSA_RAG_DATABASE_ECHO=false


# =========================================================
# S3 Object Key Validation
# =========================================================
# RAG는 S3에 직접 인증하지 않습니다.
#
# 이 값은 애플리케이션 서버가 전달한 Object Key가
# 허용된 files/ 경로인지 검증할 때만 사용합니다.
JIPSA_RAG_S3_ALLOWED_KEY_PREFIX=files/


# =========================================================
# File Download
# =========================================================

# Presigned GET URL에서 허용할 호스트 suffix입니다.
# 여러 값은 쉼표로 구분합니다.
JIPSA_RAG_FILE_DOWNLOAD_ALLOWED_HOST_SUFFIXES=.amazonaws.com

# 파일 다운로드 연결 제한 시간(초)입니다.
JIPSA_RAG_FILE_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=5.0

# 다운로드 응답 청크 제한 시간(초)입니다.
JIPSA_RAG_FILE_DOWNLOAD_READ_TIMEOUT_SECONDS=60.0

# 단일 파일 최대 크기입니다.
# 기본값은 50 MiB입니다.
JIPSA_RAG_FILE_DOWNLOAD_MAX_SIZE_BYTES=52428800


# =========================================================
# Embedding Service
# =========================================================

# 임베딩 생성 서버 구현체입니다.
# 현재는 Hugging Face Text Embeddings Inference를 사용합니다.
JIPSA_RAG_EMBEDDING_PROVIDER=tei

# Windows 호스트에서 실행하는 RAG 서버가
# Docker TEI 임베딩 서버에 접근하는 기본 주소입니다.
#
# 로컬 애플리케이션 서버가 사용하는 8080 포트와 충돌하지 않도록
# TEI의 호스트 포트는 18081로 분리합니다.
JIPSA_RAG_EMBEDDING_BASE_URL=http://127.0.0.1:18081

# TEI에서 로드할 Hugging Face 임베딩 모델입니다.
JIPSA_RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Qwen3-Embedding-0.6B의 임베딩 출력 차원입니다.
JIPSA_RAG_EMBEDDING_DIM=1024

# 한 번의 TEI 요청에 포함할 최대 청크 수입니다.
# 현재 TEI 기본 최대 클라이언트 배치 크기와 동일하게 32를 사용합니다.
JIPSA_RAG_EMBEDDING_BATCH_SIZE=32

# Qdrant Collection에서 사용할 벡터 거리 함수입니다.
JIPSA_RAG_EMBEDDING_DISTANCE=cosine

# TEI 임베딩 요청의 전체 제한 시간(초)입니다.
JIPSA_RAG_EMBEDDING_TIMEOUT_SECONDS=60


# =========================================================
# Qdrant Vector Database
# =========================================================

# VectorDB 구현체입니다.
JIPSA_RAG_VECTOR_DB_PROVIDER=qdrant

# 로컬 PC에서 Docker Qdrant REST API에 접근하는 주소입니다.
JIPSA_RAG_QDRANT_URL=http://127.0.0.1:6333

# Qwen3-Embedding-0.6B의 1024차원 벡터를 저장할 Collection 이름입니다.
# 임베딩 모델이나 출력 차원이 변경되면 별도 Collection을 생성합니다.
JIPSA_RAG_QDRANT_COLLECTION=rag_chunk_vector_qwen3_embedding_0_6b_1024

# Qdrant gRPC 포트입니다.
JIPSA_RAG_QDRANT_GRPC_PORT=6334

# 초기 구현에서는 REST API를 사용합니다.
# 대량 벡터 적재 최적화가 필요해지면 true로 변경할 수 있습니다.
JIPSA_RAG_QDRANT_PREFER_GRPC=false

# 로컬 전용 Qdrant이므로 초기에는 API Key를 사용하지 않습니다.
JIPSA_RAG_QDRANT_API_KEY=

# Qdrant 요청 제한 시간(초)입니다.
JIPSA_RAG_QDRANT_TIMEOUT_SECONDS=10


# =========================================================
# Application Server
# =========================================================

# 파일 정보와 Presigned GET URL을 요청할
# 애플리케이션 서버의 기본 주소입니다.
#
# URL 끝에는 /를 붙이지 않습니다.
JIPSA_RAG_APP_SERVER_BASE_URL=http://127.0.0.1:8080

# 애플리케이션 서버 API에 공통으로 적용되는 prefix입니다.
JIPSA_RAG_APP_SERVER_API_V1_PREFIX=/api/v1

# 애플리케이션 서버 연결 제한 시간(초)입니다.
JIPSA_RAG_APP_SERVER_CONNECT_TIMEOUT_SECONDS=5.0

# 애플리케이션 서버 응답 제한 시간(초)입니다.
JIPSA_RAG_APP_SERVER_READ_TIMEOUT_SECONDS=30.0