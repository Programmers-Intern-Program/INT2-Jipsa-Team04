# =========================================================
# Jipsa RAG Environment Variable Example
# =========================================================
# .env.local, .env.development, .env.test 작성 시 참고하는 예시입니다.
#
# 이 파일에는 실제 DB 비밀번호나 내부 인증 토큰을 입력하지 않습니다.
# .env.example만 Git에 커밋하고 실제 환경별 dotenv 파일은 제외합니다.
#
# RAG는 AWS Access Key, Secret Access Key 또는 Session Token을
# 사용하지 않습니다.
#
# S3 파일은 EC2 애플리케이션 서버가 IAM Role을 사용해 발급한
# Presigned GET URL을 통해 다운로드합니다.
#
# 실행 환경 선택:
# - 미지정      -> .env.local
# - development -> .env.development
# - test        -> .env.test
#
# development 실행 예시:
#
# $env:JIPSA_RAG_APP_ENV = "development"
# uv run uvicorn jipsa_rag.main:app --reload


# =========================================================
# Application
# =========================================================

# Swagger UI와 OpenAPI 문서에 표시할 서비스 이름입니다.
JIPSA_RAG_APP_NAME="Jipsa RAG Service"

# 현재 RAG 애플리케이션 버전입니다.
JIPSA_RAG_APP_VERSION=0.1.0

# RAG API v1 엔드포인트에 공통으로 적용할 prefix입니다.
#
# POST /ingest는 루트 경로에 직접 등록되므로
# 이 prefix의 영향을 받지 않습니다.
JIPSA_RAG_API_V1_PREFIX=/api/v1

# 외부 또는 같은 네트워크의 다른 장치가 RAG 서버에 접근해야 하면
# 모든 IPv4 네트워크 인터페이스에서 수신하도록 0.0.0.0을 사용합니다.
#
# 로컬 PC에서만 접근할 경우에는 127.0.0.1로 변경할 수 있습니다.
JIPSA_RAG_HOST=0.0.0.0

# FastAPI 서버가 로컬 PC에서 실제로 수신할 내부 포트입니다.
#
# 공유기 포트 포워딩을 사용할 경우 외부 포트와 내부 포트는
# 서로 다를 수 있습니다.
JIPSA_RAG_PORT=8077

# 디버그 모드 사용 여부입니다.
JIPSA_RAG_DEBUG=true


# =========================================================
# RAG Network Exposure and Diagnostics
# =========================================================

# 백엔드 서버가 RAG 서버를 호출할 때 사용할 외부 기본 주소입니다.
#
# 허용 형식:
#
# - http://호스트:포트
# - https://호스트
# - https://호스트:포트
#
# URL 끝에는 /를 붙이지 않으며 /ingest 또는 /api/v1 같은
# API 경로를 포함하지 않습니다.
#
# TLS가 없는 DDNS와 공유기 포트 포워딩을 사용할 수 있도록
# HTTP도 허용하지만, 내부 인증 토큰 보호를 위해 HTTPS 사용을 권장합니다.
#
# 외부 주소가 아직 없거나 로컬에서만 사용하는 경우 비워 둡니다.
#
# 예:
#
# JIPSA_RAG_EXTERNAL_BASE_URL=http://rag.example.com:9802
# JIPSA_RAG_EXTERNAL_BASE_URL=https://rag.example.com
JIPSA_RAG_EXTERNAL_BASE_URL=

# RAG 외부 노출에 사용하는 터널 제공자입니다.
#
# 허용값:
#
# - none
# - cloudflare
# - ngrok
# - tailscale
# - custom
#
# DDNS와 공유기 포트 포워딩만 사용하는 경우에는 none입니다.
# cloudflare, ngrok, tailscale 또는 custom을 사용하면
# JIPSA_RAG_EXTERNAL_BASE_URL도 반드시 입력해야 합니다.
JIPSA_RAG_TUNNEL_PROVIDER=none

# 현재 RAG 프로세스가 외부 요청에 사용하는 공인 IP를 확인할 URL입니다.
#
# 기본 서비스는 다음 JSON 형식을 반환합니다.
#
# {
#   "ip": "공인 IP"
# }
JIPSA_RAG_OUTBOUND_IP_LOOKUP_URL=https://api.ipify.org?format=json

# outbound 공인 IP 조회 요청 제한 시간입니다.
#
# 단위는 초이며 최대 30초까지 허용합니다.
JIPSA_RAG_NETWORK_DIAGNOSTICS_TIMEOUT_SECONDS=5.0


# =========================================================
# Internal Service Authentication
# =========================================================

# RAG 서버가 백엔드의 /internal/** API를 호출할 때
# X-Internal-Token 헤더에 전달하는 공유 시크릿입니다.
#
# 다음 API 호출에 사용합니다.
#
# - GET /internal/files/{fileIdx}/manifest
# - POST /internal/files/{fileIdx}/ingest-complete
#
# 백엔드의 INTERNAL_TOKEN과 반드시 동일해야 합니다.
#
# 실제 토큰은 .env.local, .env.development, .env.test 또는
# 배포 환경 변수에만 저장합니다.
#
# 최소 32자 이상의 예측하기 어려운 임의 문자열을 사용합니다.
INTERNAL_TOKEN=CHANGE_ME_TO_SECURE_RANDOM_INTERNAL_TOKEN

# 백엔드가 RAG 서버의 POST /ingest 요청을 호출할 때
# X-Internal-Token 헤더에 전달하는 공유 시크릿입니다.
#
# 백엔드의 RAG_INGEST_TOKEN과 반드시 동일해야 합니다.
#
# 실제 토큰은 .env.local, .env.development, .env.test 또는
# 배포 환경 변수에만 저장합니다.
#
# 최소 32자 이상의 예측하기 어려운 임의 문자열을 사용합니다.
RAG_INGEST_TOKEN=CHANGE_ME_TO_SECURE_RANDOM_RAG_INGEST_TOKEN


# =========================================================
# Local RAG MySQL
# =========================================================

# Local RAG MySQL 서버 주소입니다.
JIPSA_RAG_DATABASE_HOST=127.0.0.1

# MySQL 연결 포트입니다.
JIPSA_RAG_DATABASE_PORT=3306

# Local RAG 데이터베이스 이름입니다.
JIPSA_RAG_DATABASE_NAME=Jipsa_Local_RAG

# Local RAG 데이터베이스 접속 계정입니다.
JIPSA_RAG_DATABASE_USER=jipsa

# 실제 환경별 dotenv 파일에서 MySQL 비밀번호로 교체합니다.
JIPSA_RAG_DATABASE_PASSWORD=CHANGE_ME_MYSQL_PASSWORD

# Local RAG DDL에서 사용하는 문자 집합입니다.
JIPSA_RAG_DATABASE_CHARSET=utf8mb4

# 애플리케이션 시작 시 SELECT 1 연결 검사 여부입니다.
JIPSA_RAG_DATABASE_CHECK_ON_STARTUP=true

# SQLAlchemy가 실행한 SQL을 콘솔에 출력할지 결정합니다.
#
# SQL과 바인딩 값이 노출될 수 있으므로 기본값은 false로 유지합니다.
JIPSA_RAG_DATABASE_ECHO=false


# =========================================================
# S3 Object Key Validation
# =========================================================

# RAG는 S3에 직접 인증하지 않습니다.
#
# 애플리케이션 서버가 전달한 S3 Object Key가
# 허용된 files/ 경로에 속하는지 검증할 때 사용합니다.
JIPSA_RAG_S3_ALLOWED_KEY_PREFIX=files/


# =========================================================
# File Download
# =========================================================

# Presigned GET URL에서 허용할 호스트 suffix입니다.
#
# 여러 값은 쉼표로 구분합니다.
JIPSA_RAG_FILE_DOWNLOAD_ALLOWED_HOST_SUFFIXES=.amazonaws.com

# Presigned URL 서버와 연결을 수립할 때 기다리는 최대 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_FILE_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=5.0

# 연결 이후 다운로드 데이터 청크를 기다리는 최대 시간입니다.
#
# 전체 다운로드 제한 시간이 아니라 연속된 데이터 청크 사이의
# 최대 대기 시간이며 단위는 초입니다.
JIPSA_RAG_FILE_DOWNLOAD_READ_TIMEOUT_SECONDS=60.0

# 다운로드할 수 있는 단일 파일의 최대 크기입니다.
#
# 기본값은 50 MiB입니다.
JIPSA_RAG_FILE_DOWNLOAD_MAX_SIZE_BYTES=52428800


# =========================================================
# Embedding Service
# =========================================================

# 임베딩 생성 서버 구현체입니다.
#
# 현재는 Hugging Face Text Embeddings Inference를 사용합니다.
JIPSA_RAG_EMBEDDING_PROVIDER=tei

# Windows 호스트에서 실행하는 RAG 서버가
# Docker TEI 임베딩 서버에 접근하는 기본 주소입니다.
#
# 백엔드가 사용하는 8080 포트와 충돌하지 않도록
# TEI의 호스트 포트는 18081로 분리합니다.
JIPSA_RAG_EMBEDDING_BASE_URL=http://127.0.0.1:18081

# TEI에서 로드할 Hugging Face 임베딩 모델입니다.
JIPSA_RAG_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Qwen3-Embedding-0.6B의 임베딩 출력 차원입니다.
JIPSA_RAG_EMBEDDING_DIM=1024

# 한 번의 TEI 요청에 포함할 최대 청크 수입니다.
#
# 현재 TEI 기본 최대 클라이언트 배치 크기와 동일하게 32를 사용합니다.
JIPSA_RAG_EMBEDDING_BATCH_SIZE=32

# Qdrant Collection에서 사용할 벡터 거리 함수입니다.
JIPSA_RAG_EMBEDDING_DISTANCE=cosine

# TEI 임베딩 HTTP 요청의 전체 제한 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_EMBEDDING_TIMEOUT_SECONDS=60


# =========================================================
# Qdrant Vector Database
# =========================================================

# VectorDB 구현체입니다.
JIPSA_RAG_VECTOR_DB_PROVIDER=qdrant

# 로컬 PC에서 Docker Qdrant REST API에 접근하는 주소입니다.
JIPSA_RAG_QDRANT_URL=http://127.0.0.1:6333

# Qwen3-Embedding-0.6B의 1024차원 벡터를 저장할 Collection 이름입니다.
#
# 임베딩 모델이나 출력 차원이 변경되면
# 기존 Collection을 재사용하지 않고 별도 Collection을 생성합니다.
JIPSA_RAG_QDRANT_COLLECTION=rag_chunk_vector_qwen3_embedding_0_6b_1024

# Qdrant gRPC 연결 포트입니다.
JIPSA_RAG_QDRANT_GRPC_PORT=6334

# 초기 구현에서는 REST API를 사용합니다.
#
# 대량 벡터 적재 최적화가 필요해지면 true로 변경할 수 있습니다.
JIPSA_RAG_QDRANT_PREFER_GRPC=false

# 인증이 활성화된 Qdrant에서 사용할 API Key입니다.
#
# 현재 로컬 Qdrant는 API Key를 사용하지 않으므로 비워 둡니다.
JIPSA_RAG_QDRANT_API_KEY=

# Qdrant 요청 제한 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_QDRANT_TIMEOUT_SECONDS=10


# =========================================================
# Application Server
# =========================================================

# 파일 manifest 조회와 인제스트 완료 콜백을 처리할
# 애플리케이션 서버의 기본 주소입니다.
#
# URL 끝에는 /를 붙이지 않습니다.
JIPSA_RAG_APP_SERVER_BASE_URL=http://127.0.0.1:8080

# 애플리케이션 서버 일반 API에 공통으로 적용되는 prefix입니다.
#
# 현재 manifest와 ingest-complete API는 /internal/** 루트 경로이므로
# ApplicationServerIngestClient에서는 이 prefix를 사용하지 않습니다.
#
# 향후 API v1 클라이언트에서 사용할 수 있도록 설정은 유지합니다.
JIPSA_RAG_APP_SERVER_API_V1_PREFIX=/api/v1

# 애플리케이션 서버와 TCP 연결을 수립할 때 기다리는 최대 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_APP_SERVER_CONNECT_TIMEOUT_SECONDS=5.0

# 연결 후 애플리케이션 서버 응답을 기다리는 최대 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_APP_SERVER_READ_TIMEOUT_SECONDS=30.0

# 애플리케이션 서버 내부 API 요청의 최대 시도 횟수입니다.
#
# 최초 요청도 한 번의 시도에 포함됩니다.
JIPSA_RAG_APP_SERVER_MAX_ATTEMPTS=3

# 첫 번째 재시도 전에 대기할 시간입니다.
#
# 이후 재시도마다 지연 시간이 두 배로 증가합니다.
# 단위는 초입니다.
JIPSA_RAG_APP_SERVER_RETRY_INITIAL_DELAY_SECONDS=0.25

# 애플리케이션 서버 요청 재시도 사이에 허용할 최대 대기 시간입니다.
#
# 단위는 초입니다.
JIPSA_RAG_APP_SERVER_RETRY_MAX_DELAY_SECONDS=2.0