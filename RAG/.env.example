# =========================================================
# Jipsa RAG Service environment variable template
#
# 이 파일에는 실제 비밀번호, Access Key, Secret Key를 작성하지 않습니다.
# 로컬 환경에서는 이 파일을 .env.local로 복사하여 사용합니다.
# =========================================================

# Application
JIPSA_RAG_APP_NAME=Jipsa RAG Service
JIPSA_RAG_APP_VERSION=0.1.0
JIPSA_RAG_API_V1_PREFIX=/api/v1
JIPSA_RAG_DEBUG=true

# ---------------------------------------------------------
# 추후 추가 예정
# ---------------------------------------------------------

# Database
# JIPSA_RAG_DATABASE_HOST=localhost
# JIPSA_RAG_DATABASE_PORT=3306
# JIPSA_RAG_DATABASE_NAME=jipsa_rag
# JIPSA_RAG_DATABASE_USER=
# JIPSA_RAG_DATABASE_PASSWORD=

# AWS / S3
# JIPSA_RAG_AWS_REGION=ap-northeast-2
# JIPSA_RAG_S3_BUCKET=
# JIPSA_RAG_S3_ALLOWED_KEY_PREFIX=